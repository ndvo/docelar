<section class="galleries-header">
  <h1>Galeria de Fotos</h1>
  <p class="subtitle">Suas memórias organizadas por álbum</p>
</section>

<div class="gallery-actions">
  <%= button_to "Buscar novas galerias", action: "find_new_galleries", class: 'btn btn-secondary' %>
</div>

<% if @galleries.any? %>
  <div class="galleries-grid">
    <% @galleries.each do |gallery| %>
      <%= link_to gallery_path(gallery), class: 'gallery-card' do %>
        <div class="gallery-card-cover">
          <% first_photo = gallery.photos.first %>
          <% if first_photo&.file&.attached? %>
            <div class="gallery-cover-img-wrapper">
              <%= image_tag first_photo.file, loading: 'lazy', class: 'gallery-cover-img', alt: gallery.name %>
            </div>
          <% else %>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <circle cx="8.5" cy="8.5" r="1.5"/>
              <path d="M21 15l-5-5L5 21"/>
            </svg>
          <% end %>
        </div>
        <div class="gallery-card-body">
          <h2 class="gallery-card-title"><%= gallery.name %></h2>
          <p class="gallery-card-meta"><%= gallery.photos.count %> fotos</p>
        </div>
      <% end %>
    <% end %>
  </div>
<% else %>
  <div class="empty-state">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="64" height="64">
      <rect x="3" y="3" width="18" height="18" rx="2"/>
      <circle cx="8.5" cy="8.5" r="1.5"/>
      <path d="M21 15l-5-5L5 21"/>
    </svg>
    <p>Nenhuma galeria encontrada</p>
    <p class="hint">Clique em "Buscar novas galerias" para importar fotos</p>
  </div>
<% end %>
