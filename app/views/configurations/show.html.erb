<main id="main-content" role="main" aria-labelledby="config-title">
  <div class="configuration-page">
    <header class="page-header">
      <h1 id="config-title">Configurações</h1>
      <p class="subtitle">Gerencie as configurações do sistema</p>
    </header>

    <section class="config-section" aria-labelledby="appointment-types-heading">
      <h2 id="appointment-types-heading">Tipos de Consulta</h2>
      <p class="section-description">Gerencie os tipos de consulta disponíveis para os pacientes.</p>

      <div class="new-appointment-type-form">
        <h3>Novo Tipo de Consulta</h3>
        <%= form_with model: @new_appointment_type, url: '/configuration/appointment_types', local: true do |f| %>
          <div class="form-row">
            <div class="field">
              <%= f.label :name, "Nome" %>
              <%= f.text_field :name, placeholder: "checkup", required: true %>
            </div>
            <div class="field">
              <%= f.label :description, "Descrição" %>
              <%= f.text_field :description, placeholder: "Descrição do tipo de consulta" %>
            </div>
            <div class="field">
              <%= f.label :applicable_types, "Aplicável a" %>
              <%= f.text_field :applicable_types, placeholder: "Person,Dog", value: "Person,Dog" %>
            </div>
            <div class="field">
              <%= f.label :active, "Ativo" %>
              <%= f.check_box :active, checked: true %>
            </div>
            <div class="actions">
              <%= f.submit "Criar Tipo", class: 'btn btn-primary' %>
            </div>
          </div>
        <% end %>
      </div>

      <table class="config-table" role="table" aria-label="Tipos de consulta">
        <thead>
          <tr>
            <th scope="col">Nome</th>
            <th scope="col">Descrição</th>
            <th scope="col">Aplicável a</th>
            <th scope="col">Status</th>
            <th scope="col">Ações</th>
          </tr>
        </thead>
        <tbody>
          <% @appointment_types.each do |type| %>
            <tr class="<%= type.active? ? '' : 'inactive' %>">
              <%= form_with model: type, url: update_appointment_types_path(type), method: :patch do |f| %>
                <td><%= type.name.humanize %></td>
                <td>
                  <%= f.text_field :description, placeholder: "Descrição", class: 'input-sm' %>
                </td>
                <td>
                  <%= f.text_field :applicable_types, placeholder: "Person,Dog", class: 'input-sm' %>
                </td>
                <td>
                  <span class="status-badge status-<%= type.active? ? 'active' : 'inactive' %>">
                    <%= type.active? ? 'Ativo' : 'Inativo' %>
                  </span>
                </td>
                <td class="actions">
                  <%= f.submit "Salvar", class: 'btn btn-sm btn-secondary' %>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </section>

    <section class="config-section" aria-labelledby="pomodoro-goal-heading">
      <h2 id="pomodoro-goal-heading">Meta Pomodoro Diária</h2>
      <p class="section-description">Defina quantos pomodoros (25min) deseja completar por dia.</p>

      <%= form_with model: current_user, url: update_pomodoro_goal_path, method: :patch, local: true do |f| %>
        <div class="form-row">
          <div class="field">
            <%= f.label :daily_pomodoro_goal, "Pomodoros por dia" %>
            <%= f.number_field :daily_pomodoro_goal, min: 1, max: 50, class: 'input-sm' %>
          </div>
          <div class="actions">
            <%= f.submit "Salvar Meta", class: 'btn btn-primary' %>
          </div>
        </div>
      <% end %>
    </section>

    <section class="config-section" aria-labelledby="fonts-heading">
      <h2 id="fonts-heading">Fontes</h2>
      <p class="section-description">Gerencie as fontes personalizadas para os cartões.</p>

      <div class="new-font-form">
        <h3>Nova Fonte</h3>
        <%= form_with model: @new_font, url: configuration_fonts_path, local: true do |f| %>
          <div class="form-row">
            <div class="field">
              <%= f.label :name, "Nome" %>
              <%= f.text_field :name, placeholder: "Dancing Script", required: true %>
            </div>
            <div class="field">
              <%= f.label :description, "Descrição" %>
              <%= f.text_field :description, placeholder: "Elegante e cursiva" %>
            </div>
            <div class="field">
              <%= f.label :file, "Arquivo (TTF/OTF)" %>
              <%= f.file_field :file, accept: ".ttf,.otf,.woff,.woff2", required: true %>
            </div>
            <div class="actions">
              <%= f.submit "Adicionar Fonte", class: 'btn btn-primary' %>
            </div>
          </div>
        <% end %>
      </div>

      <div class="fonts-list">
        <% @fonts.each do |font| %>
          <div class="font-item">
            <style>
              @font-face {
                font-family: 'custom-font-<%= font.id %>';
                src: url('<%= url_for(font.file) %>') format('truetype');
              }
            </style>
            <div class="font-preview" style="font-family: 'custom-font-<%= font.id %>', sans-serif;">AaBbCc 123</div>
            <div class="font-info">
              <strong><%= font.name %></strong>
              <% if font.description.present? %>
                <p><%= font.description %></p>
              <% end %>
            </div>
            <div class="font-actions">
              <%= link_to 'Remover', configuration_font_path(font), method: :delete, data: { confirm: 'Tem certeza?' }, class: 'btn btn-sm btn-danger' %>
            </div>
          </div>
        <% end %>
      </div>
    </section>
  </div>
</main>