<main id="main-content">
  <nav class="breadcrumb">
    <%= link_to '← Voltar', @patient %>
  </nav>

  <div class="health-hub">
    <header class="health-hub-header">
      <h1>Resumo de Saúde</h1>
      <%= link_to 'Editar Perfil', edit_patient_path(@patient), class: 'btn btn-secondary' %>
    </header>

    <div class="health-summary-cards">
      <div class="summary-card appointments">
        <div class="card-count"><%= @patient.medical_appointments.upcoming.count %></div>
        <div class="card-label">Próximas Consultas</div>
        <% if @upcoming_appointments.any? %>
          <ul class="card-list">
            <% @upcoming_appointments.each do |appt| %>
              <li>
                <strong><%= appt.appointment_type.humanize %></strong>
                <span><%= l(appt.appointment_date, format: :short) %></span>
              </li>
            <% end %>
          </ul>
        <% end %>
        <%= link_to 'Ver Todas', patient_medical_appointments_path(@patient), class: 'card-link' %>
      </div>

      <div class="summary-card conditions">
        <div class="card-count"><%= @active_conditions.count %></div>
        <div class="card-label">Condições Ativas</div>
        <% if @active_conditions.any? %>
          <ul class="card-list">
            <% @active_conditions.first(3).each do |condition| %>
              <li>
                <strong><%= condition.condition_name %></strong>
                <span class="status-badge status-<%= condition.status %>"><%= condition.status.humanize %></span>
              </li>
            <% end %>
          </ul>
        <% end %>
        <%= link_to 'Ver Todas', patient_medical_conditions_path(@patient), class: 'card-link' %>
      </div>

      <div class="summary-card treatments">
        <div class="card-count"><%= @active_treatments.count %></div>
        <div class="card-label">Tratamentos Ativos</div>
        <% if @active_treatments.any? %>
          <ul class="card-list">
            <% @active_treatments.first(3).each do |treatment| %>
              <li>
                <strong><%= treatment.pharmacotherapies.count %> medicamentos</strong>
                <span>Iniciado em <%= l(treatment.start_date, format: :short) %></span>
              </li>
            <% end %>
          </ul>
        <% end %>
        <%= link_to 'Ver Todos', patient_treatments_path(@patient), class: 'card-link' %>
      </div>

      <div class="summary-card exams">
        <div class="card-count"><%= @patient.medical_exams.count %></div>
        <div class="card-label">Exames Realizados</div>
        <% if @recent_exams.any? %>
          <ul class="card-list">
            <% @recent_exams.first(3).each do |exam| %>
              <li>
                <strong><%= exam.exam_type.humanize %></strong>
                <span><%= l(exam.exam_date, format: :short) %></span>
              </li>
            <% end %>
          </ul>
        <% end %>
        <%= link_to 'Ver Todos', patient_medical_exams_path(@patient), class: 'card-link' %>
      </div>
    </div>

    <nav class="health-hub-tabs" role="tablist">
      <%= link_to 'Visão Geral', patient_health_path(@patient), class: 'tab active' %>
      <%= link_to 'Consultas', patient_medical_appointments_path(@patient), class: 'tab' %>
      <%= link_to 'Condições', patient_medical_conditions_path(@patient), class: 'tab' %>
      <%= link_to 'Medicamentos', patient_treatments_path(@patient), class: 'tab' %>
      <%= link_to 'Exames', patient_medical_exams_path(@patient), class: 'tab' %>
      <%= link_to 'Histórico Familiar', patient_family_medical_histories_path(@patient), class: 'tab' %>
    </nav>

    <section class="quick-actions">
      <h2>Ações Rápidas</h2>
      <div class="action-buttons">
        <%= link_to 'Nova Consulta', new_patient_medical_appointment_path(@patient), class: 'btn btn-primary' %>
        <%= link_to 'Solicitar Exame', new_patient_exam_request_path(@patient), class: 'btn btn-secondary' %>
        <%= link_to 'Nova Condição', new_patient_medical_condition_path(@patient), class: 'btn btn-secondary' %>
        <%= link_to 'Novo Histórico', new_patient_family_medical_history_path(@patient), class: 'btn btn-secondary' %>
      </div>
    </section>
  </div>
</main>
