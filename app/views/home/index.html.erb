<!-- Dashboard Header -->
<header class="dashboard-header">
  <h1>Bem-vindo ao Doce Lar</h1>
</header>

<!-- Quick Stats Bar -->
<section class="quick-stats" aria-label="Estatísticas rápidas">
  <div class="quick-stat-item">
    <output class="quick-stat-number"><%= @tasks_pending || 0 %></output>
    <span class="quick-stat-label">Tarefas pendentes</span>
  </div>
  <div class="quick-stat-item">
    <output class="quick-stat-number"><%= @payments_due || 0 %></output>
    <span class="quick-stat-label">Pagamentos a vencer</span>
  </div>
  <div class="quick-stat-item">
    <output class="quick-stat-number"><%= @pets_count || 0 %></output>
    <span class="quick-stat-label">Pets</span>
  </div>
  <div class="quick-stat-item">
    <output class="quick-stat-number"><%= (@photos_count || 0) + (@videos_count || 0) %></output>
    <span class="quick-stat-label">Mídias</span>
  </div>
</section>

<!-- Dashboard Widgets -->
<section class="dashboard-widgets" aria-label="Seus widgets">
  <% if @upcoming_tasks && !@upcoming_tasks.empty? %>
    <div class="dashboard-widget">
      <h2>Tarefas Recentes</h2>
      <ul class="task-list">
        <% @upcoming_tasks.take(5).each do |task| %>
          <li class="task-item">
            <span class="task-title"><%= task.name %></span>
          </li>
        <% end %>
      </ul>
      <%= link_to "Ver todas →", tasks_path, class: "widget-link" %>
    </div>
  <% end %>

  <% if @recent_activity && !@recent_activity.empty? %>
    <div class="dashboard-widget recent-activity">
      <h2>Atividade Recente</h2>
      <ul class="activity-list">
        <% @recent_activity.each do |activity| %>
          <li class="activity-item">
            <span class="activity-icon <%= activity[:icon] %>"></span>
            <div class="activity-content">
              <p class="activity-text"><%= activity[:text] %></p>
              <span class="activity-time"><%= activity[:time] %></span>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>
</section>

