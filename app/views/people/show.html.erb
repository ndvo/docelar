<main id="main-content" class="person-show medication-hub" role="main" aria-labelledby="person-name">
  <header class="person-profile-header">
    <h1 id="person-name"><%= @person.name %></h1>
  </header>

  <section class="person-details card">
    <h2>Detalhes</h2>
    <dl>
      <% if @person.borned_on %>
        <div>
          <dt>Data de Nascimento</dt>
          <dd><%= l(@person.borned_on, format: :default) %></dd>
        </div>
      <% end %>
      <% if @person.dead_on %>
        <div>
          <dt>Data de Falecimento</dt>
          <dd><%= l(@person.dead_on, format: :default) %></dd>
        </div>
      <% end %>
      <% if @person.nationalities.any? %>
        <div>
          <dt>Nacionalidades</dt>
          <dd><%= @person.nationalities.map { |n| n.country.name }.join(", ") %></dd>
        </div>
      <% end %>
    </dl>
  </section>

  <% patient = Patient.find_by(individual: @person) %>

  <% if patient %>
    <section class="patient-health-link">
      <%= link_to 'Ver Saúde', health_patient_path(patient), class: 'btn btn-primary' %>
    </section>
  <% else %>
    <div class="empty-message">
      <p>Esta pessoa não é um paciente.</p>
      <%= button_to 'Tornar Paciente', patients_path(patient: { individual_id: @person.id, individual_type: 'Person' }), method: :post, class: 'btn btn-primary' %>
    </div>
  <% end %>

  <nav class="person-nav">
    <%= link_to 'Editar', edit_person_path(@person), class: 'btn btn-secondary' %>
    <%= link_to 'Voltar', people_path, class: 'cancel-link' %>
  </nav>
</main>
