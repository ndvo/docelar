<h1>Editar Fundo</h1>

<%= link_to '← Voltar', letter_backgrounds_path %>

<%= render 'form', letter_background: @letter_background %>

<% if @letter_background.image.attached? || @letter_background.photo&.file&.attached? %>
<div class="filter-editor" data-controller="filter-editor" data-filter-editor-letter-background-id-value="<%= @letter_background.id %>">
  <h2>Filtros</h2>

  <div class="filter-preview" data-filter-editor-target="previewContainer">
    <div class="loading-overlay" style="display:none;">
      <span class="spinner"></span>
    </div>
    <%= image_tag "/letter_backgrounds/#{@letter_background.id}/preview", id: "background_preview", size: "300x300" %>
  </div>

  <div class="filter-status-message" data-filter-editor-target="statusMessage"></div>

  <div class="filter-list" data-filter-editor-target="filterList">
    Carregando...
  </div>

  <div class="filter-buttons">
    <button type="button" class="btn" data-action="filter-editor#addBlur">
      <span class="btn-icon">💧</span> Blur
    </button>
    <button type="button" class="btn" data-action="filter-editor#addGrayscale">
      <span class="btn-icon">⬛</span> P&amp;B
    </button>
    <button type="button" class="btn" data-action="filter-editor#addContrast">
      <span class="btn-icon">◐</span> Contraste
    </button>
    <button type="button" class="btn btn-danger" data-action="filter-editor#addBlack">
      <span class="btn-icon">⬛</span> Preto
    </button>
  </div>

  <div class="filter-actions">
    <button type="button" class="btn btn-primary btn-lg" data-filter-editor-target="applyBtn" data-action="filter-editor#applySelectedFilters">
      Aplicar Filtros
    </button>
    <button type="button" class="btn" data-filter-editor-target="resetBtn" data-action="filter-editor#resetFilters">
      Limpar Tudo
    </button>
  </div>
</div>

<style>
.filter-editor { max-width: 500px; margin: 20px auto; }
.filter-preview { position: relative; margin-bottom: 15px; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.15); }
.filter-preview img { display: block; width: 100%; height: auto; }
.loading-overlay { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(255,255,255,0.8); display: flex; align-items: center; justify-content: center; }
.filter-editor.loading .loading-overlay { display: flex; }
.spinner { width: 32px; height: 32px; border: 3px solid #eee; border-top-color: #333; border-radius: 50%; animation: spin 0.8s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }

.filter-status-message { min-height: 24px; padding: 8px 12px; margin-bottom: 10px; border-radius: 4px; font-size: 14px; text-align: center; }
.filter-status-message.success { background: #d4edda; color: #155724; }
.filter-status-message.error { background: #f8d7da; color: #721c24; }

.filter-list { margin-bottom: 15px; }
.filter-list-header { font-weight: 600; margin-bottom: 8px; color: #555; }
.filter-item { display: flex; align-items: center; justify-content: space-between; padding: 10px 12px; margin-bottom: 6px; background: #f8f9fa; border-radius: 6px; }
.filter-item-name { font-weight: 500; }
.filter-item .btn-sm { width: 28px; height: 28px; padding: 0; font-size: 16px; }

.filter-buttons { display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px; margin-bottom: 15px; }
.filter-buttons .btn { padding: 12px 16px; display: flex; align-items: center; justify-content: center; gap: 8px; }
.btn-icon { font-size: 18px; }

.filter-actions { display: flex; gap: 10px; }
.filter-actions .btn-lg { flex: 1; padding: 14px; font-size: 16px; }
</style>
<% end %>