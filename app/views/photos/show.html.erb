<nav class="breadcrumb">
  <%= link_to '← Galerias', galleries_path, data: { turbo_preload: true } %>
  <span class="separator">/</span>
  <%= link_to @photo.gallery.name, @photo.gallery, data: { turbo_preload: true } %>
</nav>

<div class="photo-detail">
  <article class="photo">
    <h1><%= @photo.title %></h1>
    <% if @photo.file.attached? %>
      <div class="photo-full">
        <picture>
          <source media="(min-width: 1200px)" srcset="<%= url_for(@photo.file) %>">
          <source media="(min-width: 800px)" srcset="<%= @photo.medium_url %>">
          <img src="<%= @photo.medium_url %>" alt="<%= @photo.title %>" loading="eager">
        </picture>
      </div>
    <% else %>
      <div class="empty-state">
        <p>Imagem não disponível</p>
      </div>
    <% end %>
  </article>

  <nav class="photo-nav">
    <div class="nav-arrow">
      <%= link_to '← Anterior', 
          @photo.previous || @photo.gallery.photos.order(:id).last, 
          class: 'btn btn-secondary', 
          data: { turbo_preload: true } %>
    </div>

    <div class="photo-position">
      <span class="position-text"><%= @photo.gallery.photos.order(:id).index(@photo) + 1 %> / <%= @photo.gallery.photos.count %></span>
      <div class="position-bar">
        <div class="position-progress" style="width: <%= ((@photo.gallery.photos.order(:id).index(@photo) + 1).to_f / @photo.gallery.photos.count * 100).round %>%"></div>
      </div>
    </div>

    <div class="photo-tags">
      <%= turbo_frame_tag "taggeds" do %>
        <%= render @photo.tags %>
        <%= form_with model: [TaggedPhoto.new], data: { turbo_frame: "tags" } do |form| %>
          <div class="tag-input">
            <%= text_field_tag :tag_name, nil, list: 'tags_names', placeholder: 'Adicionar tag' %>
            <%= form.hidden_field :photo_id, value: @photo.id %>
            <%= form.submit '+', class: 'btn-tag' %>
          </div>
        <% end %>

        <%= content_tag(:datalist, nil, id: 'tags_names') do %>
          <% @existing_tags.each do |tag| %>
            <%= content_tag(:option, nil, value: tag) %>
          <% end %>
        <% end %>
      <% end %>
    </div>

    <div class="nav-arrow">
      <%= link_to 'Próxima →', 
          @photo.next || @photo.gallery.photos.order(:id).first, 
          class: 'btn btn-secondary', 
          data: { turbo_preload: true } %>
    </div>
  </nav>
</div>

<script>
document.addEventListener('keydown', function(e) {
  if (e.key === 'ArrowLeft') {
    Turbo.router.navigate('<%= @photo.previous || @photo.gallery.photos.order(:id).last&.id ? photo_path(@photo.previous || @photo.gallery.photos.order(:id).last) : '#' %>');
  } else if (e.key === 'ArrowRight') {
    Turbo.router.navigate('<%= @photo.next || @photo.gallery.photos.order(:id).first&.id ? photo_path(@photo.next || @photo.gallery.photos.order(:id).first) : '#' %>');
  }
});

// Touch swipe navigation
(function() {
  let touchStartX = 0;
  let touchStartY = 0;
  const minSwipeDistance = 50;
  const maxVerticalSwipe = 100;

  document.addEventListener('touchstart', function(e) {
    touchStartX = e.touches[0].clientX;
    touchStartY = e.touches[0].clientY;
  }, { passive: true });

  document.addEventListener('touchend', function(e) {
    const touchEndX = e.changedTouches[0].clientX;
    const touchEndY = e.changedTouches[0].clientY;
    
    const deltaX = touchEndX - touchStartX;
    const deltaY = touchEndY - touchStartY;
    
    // Only trigger if horizontal swipe is longer than vertical
    if (Math.abs(deltaX) > minSwipeDistance && Math.abs(deltaY) < maxVerticalSwipe) {
      if (deltaX > 0) {
        // Swipe right - go to previous
        Turbo.router.navigate('<%= @photo.previous || @photo.gallery.photos.order(:id).last&.id ? photo_path(@photo.previous || @photo.gallery.photos.order(:id).last) : '#' %>');
      } else {
        // Swipe left - go to next
        Turbo.router.navigate('<%= @photo.next || @photo.gallery.photos.order(:id).first&.id ? photo_path(@photo.next || @photo.gallery.photos.order(:id).first) : '#' %>');
      }
    }
  }, { passive: true });
})();
</script>
