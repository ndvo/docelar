<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <title>Docelar</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="Doce Lar - Sua gestão financeira e cuidados em um só lugar">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <a href="#main-content" class="skip-link">Pular para conteúdo principal</a>
    <header role="banner">
      <h1><a href="/">Doce Lar</a></h1>
      <%= render 'main_menu' %>
      <div id="user-status">
        <% if current_user %>
          <%= current_user.email %>
          <%= link_to 'Sair', logout_path %>
        <% else %>
          <%= link_to 'Entrar', login_path %>
        <% end %>
      </div>
    </header>
    <main id="main-content" role="main">
      <%= yield %>
    </main>
    </main>
    <%= render partial: "flash_message" %>
    <% if Rails.env.development? %>
    <%=  console %>
    <% end %>
  </body>
</html>
