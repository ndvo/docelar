<%= form_with(model: patient, data: patient.persisted? ? {} : { controller: 'patient-form-toggle' }) do |form| %>
  <% if patient.errors.any? %>
    <div id="error_explanation" role="alert" aria-labelledby="error-heading">
      <h2 id="error-heading"><%= pluralize(patient.errors.count, "erro") %> impediu save:</h2>
      <ul>
        <% patient.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <fieldset>
    <legend>Tipo de Paciente</legend>
    <div class="patient-type-selector" role="radiogroup" aria-label="Tipo de paciente">
      <label class="patient-type-option <%= (patient.individual_type || @patient_type) == 'Dog' ? 'selected' : '' %>">
        <%= form.radio_button :individual_type, 'Dog', checked: (patient.individual_type || @patient_type) == 'Dog', disabled: patient.persisted?, data: patient.persisted? ? {} : { action: 'patient-form-toggle#selectType' } %>
        <span>Cachorro</span>
      </label>
      <label class="patient-type-option <%= (patient.individual_type || @patient_type) == 'Person' ? 'selected' : '' %>">
        <%= form.radio_button :individual_type, 'Person', checked: (patient.individual_type || @patient_type) == 'Person', disabled: patient.persisted?, data: patient.persisted? ? {} : { action: 'patient-form-toggle#selectType' } %>
        <span>Pessoa</span>
      </label>
    </div>
  </fieldset>

  <div class="field">
    <%= form.label :individual_id, 'Selecione o indivíduo' %>
    <%= form.select :individual_id, 
        options_for_select(@individuals&.collect { |i| [i.name, i.id] } || [], patient.individual_id),
        { include_blank: '-- selecione --' },
        required: true, aria_label: 'Selecione o indivíduo' %>
  </div>

  <div class="actions">
    <%= form.submit 'Salvar' %>
    <%= link_to 'Cancelar', patients_path, class: 'cancel-link' %>
  </div>
<% end %>
