<main id="main-content" class="medication-page" role="main" aria-labelledby="patient-name">
  <header class="patient-header">
    <h1 id="patient-name"><%= @patient.individual.name %></h1>
    <span class="patient-type-badge">
      <%= @patient.individual_type == 'Dog' ? 'Cachorro' : 'Pessoa' %>
    </span>
  </header>

  <section class="patient-treatments" aria-labelledby="treatments-heading">
    <h2 id="treatments-heading">Tratamentos</h2>
    
    <% if @patient.treatments.any? %>
      <div class="treatments-grid">
        <% @patient.treatments.each do |treatment| %>
          <article class="treatment-card">
            <header>
              <h3><%= treatment.name %></h3>
              <span class="status-badge status-<%= treatment.status %>"><%= treatment.status %></span>
            </header>
            
            <% if treatment.pharmacotherapies.any? %>
              <ul class="medication-list">
                <% treatment.pharmacotherapies.each do |pharma| %>
                  <li>
                    <strong><%= pharma.medication.name %></strong>
                    <span><%= pharma.dosage %></span>
                  </li>
                <% end %>
              </ul>
            <% end %>
            
            <div class="treatment-actions">
              <%= link_to 'Ver Detalhes', treatment_path(treatment), class: 'btn btn-secondary' %>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <p class="empty-message">Nenhum tratamento cadastrado.</p>
      <%= link_to 'Novo Tratamento', new_patient_treatment_path(@patient), class: 'btn btn-primary' %>
    <% end %>
  </section>

  <section class="patient-appointments" aria-labelledby="appointments-heading">
    <h2 id="appointments-heading">Consultas</h2>
    
    <% appointments = @patient.medical_appointments.order(appointment_date: :desc).limit(5).to_a %>
    
    <% if appointments.any? %>
      <div class="appointments-list">
        <% appointments.each do |appointment| %>
          <article class="appointment-card">
            <header>
              <h3><%= appointment.appointment_type.humanize %></h3>
              <span class="status-badge status-<%= appointment.status %>"><%= appointment.status.humanize %></span>
            </header>
            
            <div class="appointment-date">
              <%= l(appointment.appointment_date, format: :long) if appointment.appointment_date %>
            </div>
            
            <% if appointment.specialty || appointment.professional_name %>
              <div class="appointment-details">
                <%= appointment.specialty if appointment.specialty %>
                <%= " - Dr(a). #{appointment.professional_name}" if appointment.professional_name %>
              </div>
            <% end %>
            
            <div class="appointment-actions">
              <%= link_to 'Ver', patient_medical_appointment_path(@patient, appointment), class: 'btn btn-secondary btn-sm' %>
            </div>
          </article>
        <% end %>
      </div>
      <%= link_to 'Ver Todas as Consultas', patient_medical_appointments_path(@patient), class: 'btn btn-secondary' %>
    <% else %>
      <p class="empty-message">Nenhuma consulta agendada.</p>
    <% end %>
    
    <%= link_to 'Nova Consulta', new_patient_medical_appointment_path(@patient), class: 'btn btn-primary' %>
  </section>

  <section class="patient-exams" aria-labelledby="exams-heading">
    <h2 id="exams-heading">Exames</h2>
    
    <% exams = @patient.medical_exams.order(exam_date: :desc).limit(5).to_a %>
    
    <% if exams.any? %>
      <div class="exams-list">
        <% exams.each do |exam| %>
          <article class="exam-card">
            <header>
              <h3><%= exam.exam_type.humanize %></h3>
              <span class="status-badge status-<%= exam.status %>"><%= exam.status.humanize %></span>
            </header>
            
            <div class="exam-date">
              <%= l(exam.exam_date, format: :long) if exam.exam_date %>
            </div>
            
            <% if exam.name || exam.laboratory %>
              <div class="exam-details">
                <%= exam.name if exam.name %>
                <%= " - #{exam.laboratory}" if exam.laboratory %>
              </div>
            <% end %>
            
            <div class="exam-actions">
              <%= link_to 'Ver', patient_medical_exam_path(@patient, exam), class: 'btn btn-secondary btn-sm' %>
            </div>
          </article>
        <% end %>
      </div>
      <%= link_to 'Ver Todos os Exames', patient_medical_exams_path(@patient), class: 'btn btn-secondary' %>
    <% else %>
      <p class="empty-message">Nenhum exame registrado.</p>
    <% end %>
    
    <%= link_to 'Novo Exame', new_patient_medical_exam_path(@patient), class: 'btn btn-primary' %>
  </section>

  <section class="patient-exam-requests" aria-labelledby="exam-requests-heading">
    <h2 id="exam-requests-heading">Solicitações de Exames</h2>
    
    <% exam_requests = @patient.exam_requests.order(requested_date: :desc).limit(5).to_a %>
    
    <% if exam_requests.any? %>
      <ul class="exam-requests-list">
        <% exam_requests.each do |request| %>
          <li class="exam-request-card">
            <div class="request-name"><%= request.exam_name %></div>
            <span class="status-badge status-<%= request.status %>"><%= request.status.humanize %></span>
            <div class="request-date">
              <%= l(request.requested_date, format: :long) if request.requested_date %>
            </div>
          </li>
        <% end %>
      </ul>
      <%= link_to 'Ver Todas as Solicitações', patient_exam_requests_path(@patient), class: 'btn btn-secondary' %>
    <% else %>
      <p class="empty-message">Nenhuma solicitação de exame.</p>
    <% end %>
    
    <%= link_to 'Nova Solicitação', new_patient_exam_request_path(@patient), class: 'btn btn-primary' %>
  </section>

  <section class="patient-conditions" aria-labelledby="conditions-heading">
    <h2 id="conditions-heading">Condições de Saúde</h2>
    
    <% conditions = @patient.medical_conditions.order(diagnosed_date: :desc).limit(5).to_a %>
    
    <% if conditions.any? %>
      <ul class="conditions-list">
        <% conditions.each do |condition| %>
          <li class="condition-card">
            <div class="condition-name"><%= condition.condition_name %></div>
            <span class="status-badge status-<%= condition.status %>"><%= condition.status.humanize %></span>
            <div class="condition-date">
              <%= l(condition.diagnosed_date, format: :long) if condition.diagnosed_date %>
            </div>
          </li>
        <% end %>
      </ul>
      <%= link_to 'Ver Todas as Condições', patient_medical_conditions_path(@patient), class: 'btn btn-secondary' %>
    <% else %>
      <p class="empty-message">Nenhuma condição registrada.</p>
    <% end %>
    
    <%= link_to 'Nova Condição', new_patient_medical_condition_path(@patient), class: 'btn btn-primary' %>
  </section>

  <section class="patient-family-history" aria-labelledby="family-history-heading">
    <h2 id="family-history-heading">Histórico Familiar</h2>
    
    <% family_histories = @patient.family_medical_histories.order(diagnosed_relative_date: :desc).limit(5).to_a %>
    
    <% if family_histories.any? %>
      <ul class="family-history-list">
        <% family_histories.each do |history| %>
          <li class="family-history-card">
            <div class="history-condition"><%= history.condition_name %></div>
            <span class="history-relation"><%= history.relation.humanize %></span>
            <div class="history-date">
              <%= l(history.diagnosed_relative_date, format: :long) if history.diagnosed_relative_date %>
            </div>
          </li>
        <% end %>
      </ul>
      <%= link_to 'Ver Todo Histórico', patient_family_medical_histories_path(@patient), class: 'btn btn-secondary' %>
    <% else %>
      <p class="empty-message">Nenhum histórico familiar registrado.</p>
    <% end %>
    
    <%= link_to 'Novo Histórico', new_patient_family_medical_history_path(@patient), class: 'btn btn-primary' %>
  </section>

  <section class="patient-administrations" aria-labelledby="admin-heading">
    <h2 id="admin-heading">Administrações Hoje</h2>
    
    <% today_admins = @patient.treatments.flat_map { |t| t.pharmacotherapies.flat_map { |p| p.medication_administrations.where("DATE(scheduled_at) = ?", Date.today) } } %>
    
    <% if today_admins.any? %>
      <ul class="administration-list">
        <% today_admins.each do |admin| %>
          <li class="administration-item status-<%= admin.status %>">
            <div class="admin-time">
              <%= admin.scheduled_at.strftime('%H:%M') %>
            </div>
            <div class="admin-medication">
              <%= admin.pharmacotherapy.medication.name %>
              <span class="dosage"><%= admin.pharmacotherapy.dosage %></span>
            </div>
            <div class="admin-actions">
              <% if admin.pending? %>
                <%= button_to 'Marcar como dado', 
                    medication_administration_path(admin, status: 'given'), 
                    method: :patch,
                    class: 'btn btn-success btn-sm' %>
                <%= button_to 'Pular', 
                    medication_administration_path(admin, status: 'skipped'), 
                    method: :patch,
                    class: 'btn btn-secondary btn-sm' %>
              <% else %>
                <span class="status-badge"><%= admin.status %></span>
              <% end %>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="empty-message">Nenhuma administração agendada para hoje.</p>
    <% end %>
  </section>

  <nav class="patient-nav">
    <%= link_to 'Editar', edit_patient_path(@patient), class: 'btn btn-secondary' %>
    <%= link_to 'Voltar', patients_path, class: 'cancel-link' %>
  </nav>
</main>
