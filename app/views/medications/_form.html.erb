<%= form_with(model: medication, class: 'medication-form') do |form| %>
  <% if medication.errors.any? %>
    <div id="error_explanation" role="alert">
      <h2><%= pluralize(medication.errors.count, "error") %> prohibited this medication from being saved:</h2>
      <ul>
        <% medication.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <fieldset>
    <legend>Informações do Medicamento</legend>

    <div class="field">
      <%= form.label :name, 'Nome' %>
      <%= form.text_field :name, required: true %>
    </div>

    <div class="field">
      <%= form.label :active_principle, 'Princípio Ativo' %>
      <%= form.text_field :active_principle %>
    </div>

    <div class="field">
      <%= form.label :description, 'Descrição' %>
      <%= form.text_area :description, rows: 3 %>
    </div>

    <div class="field-row">
      <div class="field">
        <%= form.label :dosage, 'Dosagem' %>
        <%= form.text_field :dosage, placeholder: 'ex: 10mg' %>
      </div>

      <div class="field">
        <%= form.label :unit, 'Unidade' %>
        <%= form.text_field :unit, placeholder: 'ex: mg, ml' %>
      </div>
    </div>
  </fieldset>

  <div class="actions">
    <%= link_to 'Cancelar', medications_path, class: 'cancel-link' %>
    <%= form.submit 'Salvar' %>
  </div>
<% end %>
