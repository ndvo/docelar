<%= render 'simple_month_navigator', { date: @chosen_month } %>

<h1>Compras do mês <%= @chosen_month.strftime("%Y/%m") %></h1>

<div class="actions">
  <%= link_to "Cadastrar compra", new_purchase_path %>
</div>

<%= render 'simple_table', {
  keys: %w(Produto Estabelecimento Preço), 
  rows: @purchases.map { |p| [
    (link_to p.product.name, p),
    p.merchant || '-',
    p.price,
  ]}
}
  %>
