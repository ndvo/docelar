<%= form_with model: purchase, class: 'purchase-form', data: { controller: 'purchase-form form' } do |f| %>
  <% if purchase.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(purchase.errors.count, "error") %> prohibited this purchase from being saved:</h2>
      <ul>
        <% purchase.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <fieldset>
    <legend>Informações</legend>
    <div class="field">
      <%= f.label :purchase_at, 'Data' %>
      <%= f.date_field :purchase_at %>
    </div>
  </fieldset>

  <fieldset>
    <legend>Produto</legend>
    <div class="field">
      <%= f.label :product_id, 'Produto' %>
      <div class="product-select" data-controller="product-toggle">
        <div class="product-select-row">
          <%= f.select :product_id,
              content_tag(:option, '-- nenhum --', value: '') +
              options_from_collection_for_select(
                @products, 'id', 'name',
                @purchase.product_id
              ),
              { id: 'product-select' },
              'data-product-toggle-target' => 'select',
              'data-action' => 'product-toggle#onProductChange'
            %>
          <button type="button" 
                  class="btn btn-secondary product-toggle-btn"
                  data-product-toggle-target="toggle"
                  data-action="product-toggle#toggle"
                  aria-label="Criar novo produto">
            <span class="toggle-label">+ Novo</span>
            <span class="toggle-icon" aria-hidden="true">+</span>
          </button>
        </div>
        <div class="product-form-fields" 
             data-product-toggle-target="form"
             hidden>
          <%= f.fields_for :product do |ff| %>
            <div class="product-form-grid">
              <div class="field">
                <%= ff.label :name, 'Nome' %>
                <%= ff.text_field :name %>
              </div>
              <div class="field">
                <%= ff.label :brand, 'Marca' %>
                <%= ff.text_field :brand %>
              </div>
              <div class="field">
                <%= ff.label :kind, 'Tipo' %>
                <%= ff.text_field :kind %>
              </div>
              <div class="field">
                <%= ff.label :description, 'Descrição' %>
                <%= ff.text_area :description %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="price-quantity-row">
      <div class="field">
        <%= f.label :price, 'Preço Unitário' %>
        <div class="input-with-prefix">
          <span class="prefix">R$</span>
          <%= f.number_field :price, step: 0.01, 
              'data-action' => 'purchase-form#onPriceChange', 
              'data-purchase-form-target' => 'price' %>
        </div>
      </div>

      <div class="field quantity-field">
        <%= f.label :quantity, 'Quantidade' %>
        <%= f.number_field :quantity, step: 1, value: @purchase.quantity || 1,
            'data-action' => 'purchase-form#onQuantityChange', 
            'data-purchase-form-target' => 'quantity' %>
      </div>
    </div>
  </fieldset>

  <fieldset>
    <legend>Pagamento</legend>
    <div class="field">
      <%= f.label :card_id, 'Cartão' %>
      <%= f.hidden_field :card_id, 'data-card-picker-target': 'input' %>
      <div class="card-picker" data-controller="card-picker">
        <div class="card-picker-grid">
          <% Card.all.each do |card| %>
            <button type="button" 
                    class="card-picker-option <%= 'selected' if @purchase.card_id == card.id %>"
                    data-card-id="<%= card.id %>"
                    data-action="click->card-picker#select">
              <span class="card-brand"><%= card.brand %></span>
              <span class="card-name"><%= card.name %></span>
              <span class="card-number"><%= card.masked_number %></span>
            </button>
          <% end %>
        </div>
      </div>
    </div>

    <div class="installments-grid">
      <div class="field">
        <%= f.label :number_of_installments, 'Parcelas' %>
        <%= f.number_field :number_of_installments, min: 1, value: @purchase.number_of_installments, 
            'data-purchase-form-target' => 'installments', 
            'data-action' => 'purchase-form#onPriceChange' %>
      </div>

      <div class="field">
        <%= f.label :installment_price, 'Valor da Parcela' %>
        <div class="input-with-prefix">
          <span class="prefix">R$</span>
          <%= f.number_field :installment_price, step: 0.01, 
              'data-action' => 'change->purchase-form#onInstallmentPriceChange', 
              'data-purchase-form-target' => 'installmentPrice' %>
        </div>
      </div>
    </div>

    <div class="payment-footer">
      <div class="total-display">
        <span class="total-label">Total:</span>
        <span data-purchase-form-target="total" class="total-amount">R$ 0,00</span>
      </div>

      <div class="field checkbox-field paid-field">
        <%= f.check_box :paid, id: 'purchase_paid' %>
        <%= f.label :paid, 'Pago', for: 'purchase_paid' %>
      </div>
    </div>
  </fieldset>

  <div class="actions">
    <%= link_to 'Cancelar', purchases_path, class: 'cancel-link' %>
    <%= f.submit %>
  </div>
<% end %>
