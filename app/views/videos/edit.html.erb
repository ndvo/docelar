<h1>Editar Vídeo</h1>

<%= form_with(model: @video, local: true, html: { multipart: true, data: { turbo: false } }) do |form| %>
  <% if @video.errors.any? %>
    <div class="error-messages">
      <h2><%= pluralize(@video.errors.count, "error") %> prohibited this video from being saved:</h2>
      <ul>
        <% @video.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :title %>
    <%= form.text_field :title, required: true %>
  </div>

  <div class="field">
    <%= form.label :description %>
    <%= form.text_area :description %>
  </div>

  <div class="field">
    <%= form.label :file, "Arquivo de Vídeo" %>
    <%= form.file_field :file, accept: "video/*" %>
    <% if @video.file.attached? %>
      <p class="help">Arquivo atual: <%= @video.file.filename %></p>
    <% end %>
    <p class="help">MP4, WebM, MOV, AVI (max 4GB) - Deixe vazio para manter o atual</p>
  </div>

  <div class="field">
    <%= form.label :external_url, "URL Externa (Archive.org, YouTube, etc.)" %>
    <%= form.url_field :external_url, placeholder: "https://archive.org/..." %>
  </div>

  <div class="field">
    <%= form.check_box :is_external %>
    <%= form.label :is_external, "Vídeo externo (não fazer stream do servidor)" %>
  </div>

  <% if @video.file.attached? %>
    <div class="field">
      <%= form.check_box :enhance_audio %>
      <%= form.label :enhance_audio, "🔊 Melhorar áudio (reduzir ruído de fundo)" %>
      <% case @video.enhance_audio_status %>
      <% when "pending" %>
        <p class="help">Aguardando processamento...</p>
      <% when "processing" %>
        <p class="help">Processando áudio... (pode levar alguns minutos)</p>
      <% when "completed" %>
        <p class="help">✅ Áudio enhancement completo</p>
      <% when "failed" %>
        <p class="help" style="color: red;">❌ Processamento falhou</p>
      <% else %>
        <p class="help">Remove ruído de fundo para destacar vozes humanas</p>
      <% end %>
    </div>

    <div class="field">
      <%= form.label :crop, "✂️ Cortar bordas (recortar vídeo)" %>
      <div class="crop-selector" id="crop-selector-el">
        <video id="crop-video-preview" src="<%= url_for(@video.file) %>" muted preload="auto"></video>
        <div class="crop-overlay" id="crop-overlay-el">
          <div class="crop-selection" id="crop-selection-el"></div>
        </div>
      </div>
      <div class="crop-controls">
        <div class="crop-inputs">
          <%= form.hidden_field :crop_x, id: "crop_x", value: @video.crop_x %>
          <%= form.hidden_field :crop_y, id: "crop_y", value: @video.crop_y %>
          <%= form.hidden_field :crop_width, id: "crop_width", value: @video.crop_width %>
          <%= form.hidden_field :crop_height, id: "crop_height", value: @video.crop_height %>
          <span>
            <label>X:</label> <input type="number" id="crop_x_disp" value="<%= @video.crop_x || 0 %>" min="0"> 
            <label>Y:</label> <input type="number" id="crop_y_disp" value="<%= @video.crop_y || 0 %>" min="0"> 
            <label>L:</label> <input type="number" id="crop_w_disp" value="<%= @video.crop_width || '' %>" min="1"> 
            <label>A:</label> <input type="number" id="crop_h_disp" value="<%= @video.crop_height || '' %>" min="1">
          </span>
        </div>
        <button type="button" id="crop-clear" class="btn btn-small">Limpar crop</button>
      </div>
      <% if @video.crop_enabled? %>
        <p class="help" style="color: green;">✂️ Crop configurado: <%= @video.crop_x %>, <%= @video.crop_y %>, <%= @video.crop_width %>x<%= @video.crop_height %></p>
      <% else %>
        <p class="help">Clique e arraste no vídeo para selecionar a área a manter</p>
      <% end %>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :video_category_id, "Categoria" %>
    <%= form.select :video_category_id, options_from_collection_for_select(@categories, :id, :name), include_blank: "Selecione..." %>
    <span>ou</span>
    <%= link_to "Criar nova categoria", "#", id: "new-category-toggle", onclick: "document.getElementById('new-category-fields').style.display='block'; document.getElementById('video_video_category_id').value=''; return false;" %>
  </div>

  <div id="new-category-fields" style="display: none;" class="field">
    <label for="new_category_name">Nova Categoria</label>
    <input type="text" name="new_category_name" id="new_category_name" placeholder="Nome da nova categoria">
    <% if @categories.any? %>
      <select name="new_category_parent_id" id="new_category_parent_id">
        <option value="">Categoria pai (opcional)</option>
        <% @categories.each do |cat| %>
          <option value="<%= cat.id %>"><%= cat.name %></option>
        <% end %>
      </select>
    <% end %>
  </div>

  <div class="field">
    <%= form.label :genre %>
    <%= form.text_field :genre %>
  </div>

  <div class="field">
    <%= form.label :release_year, "Ano de Lançamento" %>
    <%= form.number_field :release_year, min: 1900, max: Date.today.year + 5 %>
  </div>

  <div class="field">
    <%= form.label :plot_summary, "Sinopse" %>
    <%= form.text_area :plot_summary %>
  </div>

  <div class="field">
    <%= form.label :poster_url, "URL do Pôster" %>
    <%= form.url_field :poster_url, placeholder: "https://..." %>
  </div>

  <div class="actions">
    <%= form.submit "Salvar Alterações", class: "btn btn-primary" %>
    <%= link_to "Cancelar", @video, class: "btn btn-secondary" %>
  </div>
<% end %>

<script>
(function() {
  var overlay = document.getElementById('crop-overlay-el');
  var selection = document.getElementById('crop-selection-el');
  var selector = document.getElementById('crop-selector-el');
  var clearBtn = document.getElementById('crop-clear');
  
  if (!overlay || !selection) return;
  
  var isDragging = false;
  var startX, startY;
  
  overlay.addEventListener('mousedown', function(e) {
    isDragging = true;
    var rect = overlay.getBoundingClientRect();
    startX = e.clientX - rect.left;
    startY = e.clientY - rect.top;
    selector.classList.add('dragging');
    selection.style.left = startX + 'px';
    selection.style.top = startY + 'px';
    selection.style.width = '0px';
    selection.style.height = '0px';
    selection.style.display = 'block';
  });
  
  overlay.addEventListener('mousemove', function(e) {
    if (!isDragging) return;
    var rect = overlay.getBoundingClientRect();
    var cx = e.clientX - rect.left;
    var cy = e.clientY - rect.top;
    cx = Math.max(0, Math.min(cx, rect.width));
    cy = Math.max(0, Math.min(cy, rect.height));
    var x = Math.min(startX, cx);
    var y = Math.min(startY, cy);
    var w = Math.abs(cx - startX);
    var h = Math.abs(cy - startY);
    selection.style.left = x + 'px';
    selection.style.top = y + 'px';
    selection.style.width = w + 'px';
    selection.style.height = h + 'px';
  });
  
  overlay.addEventListener('mouseup', endDrag);
  overlay.addEventListener('mouseleave', endDrag);
  
  function endDrag() {
    if (!isDragging) return;
    isDragging = false;
    selector.classList.remove('dragging');
    var x = Math.round(parseFloat(selection.style.left));
    var y = Math.round(parseFloat(selection.style.top));
    var w = Math.round(parseFloat(selection.style.width));
    var h = Math.round(parseFloat(selection.style.height));
    if (w < 10 || h < 10) {
      clearCrop();
      return;
    }
    document.getElementById('crop_x').value = x;
    document.getElementById('crop_y').value = y;
    document.getElementById('crop_width').value = w;
    document.getElementById('crop_height').value = h;
    if (document.getElementById('crop_x_disp')) {
      document.getElementById('crop_x_disp').value = x;
      document.getElementById('crop_y_disp').value = y;
      document.getElementById('crop_w_disp').value = w;
      document.getElementById('crop_h_disp').value = h;
    }
  }
  
  function clearCrop() {
    document.getElementById('crop_x').value = 0;
    document.getElementById('crop_y').value = 0;
    document.getElementById('crop_width').value = '';
    document.getElementById('crop_height').value = '';
    selection.style.display = 'none';
  }
  
  if (clearBtn) clearBtn.addEventListener('click', clearCrop);
})();
</script>