<div class="videos-index">
  <h1>Vídeos</h1>

  <div class="video-actions">
    <%= link_to "Adicionar Vídeo", new_video_path, class: "btn btn-primary" %>
  </div>

  <% if @categories.any? %>
    <div class="categories">
      <%= link_to "Todos", videos_path, class: "btn btn-small" %>
      <% @categories.each do |category| %>
        <%= link_to category.name, videos_path(category: category.id), class: "btn btn-small" %>
      <% end %>
    </div>
  <% end %>

  <div class="video-grid">
    <% @videos.each do |video| %>
      <div class="video-card">
        <% if video.poster_url.present? %>
          <%= image_tag video.poster_url, alt: video.title, class: "video-thumbnail" %>
        <% else %>
          <div class="video-placeholder">🎬</div>
        <% end %>
        <div class="video-info">
          <h3><%= link_to video.title, video %></h3>
          <% if video.duration_seconds %>
            <span class="duration"><%= video.formatted_duration %></span>
          <% end %>
          <% if video.progress_percentage > 0 && video.progress_percentage < 100 %>
            <div class="progress-bar">
              <div class="progress" style="width: <%= video.progress_percentage %>%"></div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <% if @videos.empty? %>
    <p class="empty-state">Nenhum vídeo ainda. <%= link_to "Adicione seu primeiro vídeo", new_video_path %>.</p>
  <% end %>
</div>